# sdkconfig overlay for the Remote-ID-enabled ESP32-S3 build WITH PSRAM (Config 2: ESP32-S3-MINI-1U-N4R2).
#
# Build:  idf.py -DSDKCONFIG_DEFAULTS="sdkconfig;sdkconfig.psram" build
#
# This module has 4 MB quad flash + 2 MB quad PSRAM. Remote ID (BLE, and best-effort channel-locked WiFi sniffing)
# coexists with the existing WiFi AP/STA: the NimBLE host heap and the WiFi/LWIP buffers move to PSRAM, and software
# coexistence arbitrates the shared 2.4 GHz radio. The BLE controller and WiFi DMA descriptors must stay in internal
# RAM (hardware requirement) and cannot be moved to PSRAM.
#
# Apply this AFTER sdkconfig.remote_id's BLE options, or include both:
#   idf.py -DSDKCONFIG_DEFAULTS="sdkconfig;sdkconfig.remote_id;sdkconfig.psram" build

# --- Flash size + partition table for the 4 MB N4R2 module ---
CONFIG_ESPTOOLPY_FLASHSIZE_8MB=n
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions_remote_id_4mb.csv"

# --- Quad SPI PSRAM ---
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_QUAD=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=16384
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=49152
CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP=y
CONFIG_SPIRAM_ALLOW_BSS_SEG_EXTERNAL=y

# --- Move the NimBLE host heap to PSRAM (controller stays internal) ---
CONFIG_BT_NIMBLE_MEM_ALLOC_MODE_EXTERNAL=y

# --- WiFi + BLE software coexistence ---
CONFIG_ESP_COEX_SW_COEXIST_ENABLE=y
